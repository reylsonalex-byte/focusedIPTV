{
  "expo": {
    "name": "King IPTV",
    "slug": "kingiptv",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kingiptv",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "react-native-video",
        {
          "enableAndroidPictureInPicture": true
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT_UP"
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "android": {
      "package": "com.king.iptv",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
